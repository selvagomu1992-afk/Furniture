// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ─── COLLECTION ─────────────────────────────────
model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@map("collections")
}

// ─── SETTING ────────────────────────────────────
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─── USER ───────────────────────────────────────
model User {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String    @unique
  passwordHash    String
  phone           String?
  country         String?
  address         String?
  newsletter      Boolean   @default(false)
  role            Role      @default(CUSTOMER)
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders          Order[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── PRODUCT ─────────────────────────────────────
model Product {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  category     Category
  description  String
  basePrice    Float
  imageUrl     String?
  badge        String?
  materials    String[]   // JSON array of hex color strings
  inStock      Boolean    @default(true)
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orderItems   OrderItem[]

  @@map("products")
}

enum Category {
  LIVING
  DINING
  BEDROOM
  OFFICE
}

// ─── ORDER ───────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])

  status          OrderStatus @default(PENDING)

  // Customisation
  material        String      @default("walnut")
  finish          String      @default("natural")
  upholstery      String?
  dimension       String      @default("standard")
  customDimensions String?
  notes           String?
  timeline        String      @default("standard")

  // Pricing
  estimatedPrice  Float
  finalPrice      Float?

  // Delivery
  deliveryAddress String
  country         String

  // Payment
  paymentStatus   PaymentStatus @default(UNPAID)
  cashfreeOrderId String?
  paymentSessionId String?

  // Reference
  referenceCode   String      @unique @default(cuid())

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

// ─── ORDER ITEM ──────────────────────────────────
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  price     Float
  quantity  Int     @default(1)

  @@map("order_items")
}

// ─── PINCODE ──────────────────────────────────────
model Pincode {
  id             String  @id @default(cuid())
  pincode        String  @unique
  deliveryCharge Float
  areaName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("pincodes")
}

// ─── HERO SLIDE ──────────────────────────────────
model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String?
  subtitle  String?
  link      String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_slides")
}

// ─── FEATURED TYPE ───────────────────────────────
model FeaturedType {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("featured_types")
}

// ─── CONTACT MESSAGE ─────────────────────────────
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
